{
  "name": "koa-x-router",
  "version": "0.1.0",
  "description": "`koa-x-router` is a library that extends the functionality of `koa-router` by providing validation and automatic API documentation features. It simplifies the process of defining routes, validating request data, and generating API documentation.",
  "type": "module",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/cjs/index.d.ts",
  "typesVersions": {
    "*": {
      "joi": [
        "./dist/cjs/joi.d.ts"
      ],
      "zod": [
        "./dist/cjs/zod.d.ts"
      ]
    }
  },
  "scripts": {
    "test": "jest",
    "test:package": "node --test test/package.test.cjs",
    "lint": "eslint src test scripts --ext .ts,.js,.cjs,.mjs",
    "build": "node scripts/build.mjs",
    "prepack": "npm run build && npm run test:package",
    "prepublishOnly": "npm test && npm run lint"
  },
  "files": [
    "dist",
    "package.json",
    "README.md"
  ],
  "exports": {
    ".": {
      "import": {
        "types": "./dist/esm/index.d.ts",
        "default": "./dist/esm/index.js"
      },
      "require": {
        "types": "./dist/cjs/index.d.ts",
        "default": "./dist/cjs/index.js"
      },
      "default": "./dist/esm/index.js"
    },
    "./joi": {
      "import": {
        "types": "./dist/esm/joi.d.ts",
        "default": "./dist/esm/joi.js"
      },
      "require": {
        "types": "./dist/cjs/joi.d.ts",
        "default": "./dist/cjs/joi.js"
      },
      "default": "./dist/esm/joi.js"
    },
    "./zod": {
      "import": {
        "types": "./dist/esm/zod.d.ts",
        "default": "./dist/esm/zod.js"
      },
      "require": {
        "types": "./dist/cjs/zod.d.ts",
        "default": "./dist/cjs/zod.js"
      },
      "default": "./dist/esm/zod.js"
    }
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "keywords": [
    "koa",
    "router",
    "validation",
    "documentation",
    "openapi",
    "swagger",
    "joi",
    "yup",
    "ecubelabs"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Ecube-Labs/koa-x-router.git"
  },
  "author": "Ecube Labs Co., Ltd.",
  "license": "Apache-2.0",
  "devDependencies": {
    "@ecubelabs/prettier-config": "^0.0.8",
    "@ecubelabs/tsconfig": "^1.0.0",
    "@types/eslint": "^8",
    "@types/jest": "^29.5.2",
    "@types/koa": "^2.13.6",
    "@types/koa__router": "^12.0.0",
    "@types/koa-bodyparser": "^4.3.10",
    "@types/prettier": "^2",
    "@types/supertest": "^2.0.12",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-config-airbnb-typescript": "^18.0.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-import-resolver-typescript": "^3.6.1",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-jest": "^28.7.0",
    "eslint-plugin-prettier": "^5.2.1",
    "jest": "^29.5.0",
    "joi": "^18.2.3",
    "koa-bodyparser": "^4.4.0",
    "prettier": "^3.3.3",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.6",
    "zod": "^3.23.8"
  },
  "peerDependencies": {
    "@koa/router": ">=8.0.0",
    "joi": ">=17.0.0",
    "koa": "*",
    "zod": "^3.20.2"
  },
  "peerDependenciesMeta": {
    "joi": {
      "optional": true
    },
    "zod": {
      "optional": true
    }
  },
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^7.1.1",
    "joi-to-swagger": "^6.2.0",
    "openapi3-ts": "^4.1.2"
  }
}
