{
    "name": "@ecube-labs/koa-x-router-v0-1-adaptor-imports",
    "version": "0.1.0",
    "private": true,
    "description": "Move koa-x-router adaptor imports to the v0.1 subpath exports",
    "packageManager": "npm@10.x",
    "type": "module",
    "engines": {
        "node": ">=20.19.0"
    },
    "scripts": {
        "test": "npm run test:js && npm run test:ts",
        "test:js": "codemod jssg test ./scripts/codemod.ts tests/javascript --language javascript",
        "test:ts": "codemod jssg test ./scripts/codemod.ts tests/typescript --language tsx",
        "check": "npm run check:types && npm run check:workflow && npm test",
        "check:types": "tsc --noEmit",
        "check:workflow": "codemod workflow validate -w workflow.yaml"
    },
    "devDependencies": {
        "@codemod.com/jssg-types": "^1.6.2",
        "codemod": "^1.12.12",
        "typescript": "^5.9.3"
    }
}
